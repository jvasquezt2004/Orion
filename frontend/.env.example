# Backend origin used by server-only code (server functions, API routes).
# Defaults to http://localhost:8000 when unset.
BACKEND_URL=http://localhost:8000

# Backend origin used by browser code (e.g. gallery image URLs). Must be
# exposed with the VITE_ prefix so Vite inlines it into the client bundle.
# Defaults to http://localhost:8000 when unset.
VITE_BACKEND_URL=http://localhost:8000
